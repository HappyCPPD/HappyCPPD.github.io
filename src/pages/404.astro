---
import Base from '../layouts/Base.astro';
---

<Base title="Not found · Ashton Ang" description="That page doesn't exist.">
  <section class="shell" style="padding-block: clamp(5rem, 3rem + 10vw, 11rem); text-align: center;">
    <span class="eyebrow" style="justify-content: center;">Error 404</span>
    <h1 style="font-size: var(--step-4); margin: 1rem 0 1.25rem;">Nothing here.</h1>
    <p class="measure" style="margin-inline: auto; color: var(--paper-dim);">
      The page you were after doesn't exist, or hasn't been written yet.
    </p>
    <p style="margin-top: 2rem;">
      <a class="btn btn--solid" href="/">Back to start</a>
    </p>
  </section>
</Base>
