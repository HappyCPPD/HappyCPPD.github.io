---
// space-colonization tree backdrop
---
<canvas id="hero-canvas" class="hero-canvas" aria-hidden="true"></canvas>

<style>
  /* full-page backdrop */
  .hero-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    opacity: 0.62;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, #000 46%, #000 100%);
    mask-image: linear-gradient(90deg, transparent 0%, #000 46%, #000 100%);
    transition: transform 400ms var(--ease);
    will-change: transform;
  }
</style>

<script is:inline src="/hero-canvas.js" defer></script>
